{
    "_comment": "Gazebo integration-test config — full closed-loop with PX4 SITL",
    "log_level": "info",

    "video_capture": {
        "mission_cam": {
            "backend": "gazebo",
            "gz_topic": "/camera",
            "width": 640,
            "height": 480,
            "fps": 30,
            "format": "RGB24"
        },
        "stereo_cam": {
            "backend": "gazebo",
            "gz_topic": "/stereo_left",
            "width": 640,
            "height": 480,
            "fps": 30,
            "format": "GRAY8"
        }
    },

    "perception": {
        "detector": {
            "backend": "color_contour",
            "_comment": "Use 'yolov8' with model_path below if OpenCV is available",
            "model_path": "models/yolov8n.onnx",
            "confidence_threshold": 0.25,
            "nms_threshold": 0.45,
            "input_size": 640,
            "min_contour_area": 80
        },
        "tracker": {
            "max_age": 10,
            "min_hits": 3,
            "max_association_cost": 100.0
        },
        "fusion": {
            "lidar_weight": 0.8,
            "camera_weight": 0.2,
            "max_lidar_association_dist": 5.0,
            "max_radar_association_dist": 3.0,
            "camera_height_m": 1.5,
            "fx": 277.0,
            "fy": 277.0,
            "cx": 320.0,
            "cy": 240.0
        }
    },

    "slam": {
        "vio_rate_hz": 100,
        "visual_frontend_rate_hz": 30,
        "imu_rate_hz": 200,
        "imu": {
            "backend": "gazebo",
            "gz_topic": "/imu"
        },
        "visual_frontend": {
            "backend": "gazebo",
            "gz_topic": "/model/x500_companion_0/odometry"
        },
        "keyframe": {
            "min_parallax_px": 15.0,
            "min_tracked_ratio": 0.6,
            "max_time_sec": 0.5
        }
    },

    "mission_planner": {
        "update_rate_hz": 10,
        "takeoff_altitude_m": 5.0,
        "acceptance_radius_m": 2.0,
        "cruise_speed_mps": 5.0,
        "obstacle_avoidance": {
            "min_distance_m": 2.0,
            "influence_radius_m": 5.0,
            "repulsive_gain": 2.0
        },
        "waypoints": [
            {"x": 15, "y": 0,  "z": 5, "yaw": 0,    "speed": 5.0, "payload_trigger": false},
            {"x": 15, "y": 15, "z": 5, "yaw": 1.57,  "speed": 5.0, "payload_trigger": true},
            {"x": 0,  "y": 0,  "z": 5, "yaw": 0,     "speed": 5.0, "payload_trigger": false}
        ]
    },

    "comms": {
        "mavlink": {
            "backend": "mavlink",
            "uri": "udp://:14540",
            "timeout_ms": 8000,
            "heartbeat_rate_hz": 1,
            "tx_rate_hz": 20,
            "rx_rate_hz": 10
        },
        "gcs": {
            "backend": "simulated",
            "udp_port": 14550,
            "telemetry_rate_hz": 2
        }
    },

    "payload_manager": {
        "update_rate_hz": 50,
        "gimbal": {
            "backend": "simulated",
            "max_slew_rate_dps": 60.0,
            "pitch_min_deg": -90.0,
            "pitch_max_deg": 30.0,
            "yaw_min_deg": -180.0,
            "yaw_max_deg": 180.0
        }
    },

    "system_monitor": {
        "update_rate_hz": 1,
        "disk_check_interval_s": 10,
        "thresholds": {
            "cpu_warn_percent": 90.0,
            "mem_warn_percent": 90.0,
            "temp_warn_c": 80.0,
            "temp_crit_c": 95.0,
            "battery_warn_percent": 20.0,
            "battery_crit_percent": 10.0,
            "disk_crit_percent": 98.0
        }
    }
}
