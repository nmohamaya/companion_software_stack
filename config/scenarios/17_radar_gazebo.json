{
    "_comment": "Scenario 17: Radar Gazebo SITL — verify GazeboRadarBackend produces detections",
    "scenario": {
        "name": "radar_gazebo",
        "description": "Fly a short mission with Gazebo radar backend enabled. Validates that GazeboRadarBackend subscribes to gz-transport topics, receives gpu_lidar scans, converts them to RadarDetectionList, and the UKF fusion engine consumes them. Requires Gazebo with x500_companion model and working GPU (NVIDIA EGL).",
        "tier": 2,
        "timeout_s": 60,
        "requires_gazebo": true
    },
    "config_overrides": {
        "perception": {
            "radar": {
                "backend": "gazebo",
                "enabled": true,
                "gz_scan_topic": "/radar_lidar/scan",
                "gz_odom_topic": "/model/x500_companion_0/odometry",
                "max_range_m": 100.0,
                "fov_azimuth_rad": 1.047,
                "fov_elevation_rad": 0.262,
                "noise": {
                    "range_std_m": 0.3,
                    "azimuth_std_rad": 0.026,
                    "elevation_std_rad": 0.026,
                    "velocity_std_mps": 0.1
                },
                "false_alarm_rate": 0.02
            },
            "fusion": {
                "radar": {
                    "enabled": true,
                    "range_std_m": 0.3,
                    "azimuth_std_rad": 0.026,
                    "elevation_std_rad": 0.026,
                    "velocity_std_mps": 0.1,
                    "gate_threshold": 9.21
                }
            }
        },
        "mission_planner": {
            "takeoff_altitude_m": 5.0,
            "acceptance_radius_m": 2.0,
            "cruise_speed_mps": 2.0,
            "waypoints": [
                {"x": 10, "y": 0,  "z": 5, "yaw": 0,    "speed": 2.0, "payload_trigger": false},
                {"x": 10, "y": 10, "z": 5, "yaw": 1.57,  "speed": 2.0, "payload_trigger": false},
                {"x": 0,  "y": 0,  "z": 5, "yaw": -1.57, "speed": 2.0, "payload_trigger": false}
            ]
        }
    },
    "fault_sequence": {
        "steps": []
    },
    "pass_criteria": {
        "log_contains": [
            "TAKEOFF",
            "EXECUTING",
            "GazeboRadar.*Subscribed to scan",
            "GazeboRadar.*First scan"
        ],
        "log_must_not_contain": [
            "EMERGENCY_LAND",
            "[GazeboRadar] Failed to subscribe"
        ],
        "processes_alive": [
            "video_capture", "perception", "slam_vio_nav",
            "mission_planner", "comms", "payload_manager"
        ]
    }
}
