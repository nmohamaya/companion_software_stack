{
    "_comment": "Scenario 21: YOLOv8 Detection in Gazebo — validates OpenCvYoloDetector with full perception pipeline",
    "scenario": {
        "name": "yolov8_detection",
        "description": "Fly a short mission with YOLOv8-nano (OpenCV DNN) as the detection backend. Full pipeline: YOLOv8 detector -> ByteTrack tracker -> UKF fusion (camera+radar) -> D* Lite planner. Validates that the OpenCvYoloDetector loads the ONNX model, produces Detection2D outputs, and integrates with downstream tracking/fusion/planning. If OpenCV is not compiled in (HAS_OPENCV not defined), the factory falls back to color_contour. If OpenCV is present but the ONNX model fails to load, detect() returns empty results (no automatic fallback).",
        "tier": 2,
        "timeout_s": 120,
        "requires_gazebo": true
    },
    "config_overrides": {
        "mission_planner": {
            "takeoff_altitude_m": 5.0,
            "acceptance_radius_m": 3.0,
            "overshoot_proximity_factor": 5.0,
            "cruise_speed_mps": 1.5,
            "path_planner": {"backend": "dstar_lite", "max_search_time_ms": 1500, "max_iterations": 200000, "z_band_cells": 0, "replan_interval_s": 0.5, "look_ahead_m": 0.0, "smoothing_alpha": 0.5},
            "obstacle_avoider": {"backend": "potential_field_3d"},
            "obstacle_avoidance": {
                "min_distance_m": 2.0,
                "influence_radius_m": 8.0,
                "repulsive_gain": 3.0,
                "max_correction_mps": 1.5,
                "vertical_gain": 0.0,
                "path_aware": true
            },
            "occupancy_grid": {
                "resolution_m": 2.0,
                "inflation_radius_m": 2.0,
                "dynamic_obstacle_ttl_s": 1.0,
                "min_confidence": 0.3,
                "promotion_hits": 8
            },
            "static_obstacles": [],
            "geofence": {
                "enabled": false,
                "_comment": "Geofence disabled — D* Lite replanning may push drone toward boundary when avoiding detected obstacles"
            },
            "waypoints": [
                {"x": 0,  "y": 15, "z": 5, "yaw": 1.57,  "speed": 1.5, "payload_trigger": false, "_comment": "Fly north — camera FOV sweeps environment"},
                {"x": 10, "y": 15, "z": 5, "yaw": 0,      "speed": 1.5, "payload_trigger": false, "_comment": "Fly east — YOLOv8 detects objects in Gazebo world"},
                {"x": 10, "y": 0,  "z": 5, "yaw": -1.57,  "speed": 1.5, "payload_trigger": false, "_comment": "Fly south — tracks maintained by ByteTrack"},
                {"x": 0,  "y": 0,  "z": 5, "yaw": 3.14,   "speed": 1.5, "payload_trigger": false, "_comment": "Return home"}
            ]
        },
        "perception": {
            "detector": {
                "backend": "yolov8",
                "confidence_threshold": 0.25,
                "nms_threshold": 0.45,
                "input_size": 640,
                "max_detections": 64,
                "_comment": "YOLOv8-nano via OpenCV DNN. max_detections is only consumed by ColorContourDetector; OpenCvYoloDetector uses its own NMS output count."
            },
            "tracker": {
                "backend": "bytetrack",
                "high_conf_threshold": 0.5,
                "low_conf_threshold": 0.1,
                "max_iou_cost": 0.7,
                "_comment": "ByteTrack two-stage association for YOLOv8 detections"
            },
            "radar": {
                "backend": "gazebo",
                "enabled": true,
                "update_rate_hz": 20,
                "ground_filter_alt_m": 0.5,
                "_comment": "Radar enabled for multi-sensor fusion with YOLOv8 camera detections"
            },
            "fusion": {
                "backend": "ukf",
                "rate_hz": 30,
                "depth_scale": 1.0,
                "assumed_obstacle_height_m": 5.0,
                "radar": {
                    "enabled": true,
                    "ground_filter_enabled": true,
                    "min_object_altitude_m": 0.3,
                    "altitude_gate_m": 2.0,
                    "_comment": "Camera+radar UKF fusion — YOLOv8 provides bearing, radar provides range"
                }
            }
        }
    },
    "fault_sequence": {
        "steps": []
    },
    "pass_criteria": {
        "log_contains": [
            "Path planner: DStarLitePlanner",
            "Obstacle avoider: ObstacleAvoider3D",
            "Detector backend: yolov8",
            "Tracker  backend: bytetrack",
            "TAKEOFF",
            "EXECUTING",
            "Mission complete"
        ],
        "log_must_not_contain": [
            "EMERGENCY_LAND",
            "OBSTACLE COLLISION",
            "falling back to 'color_contour'"
        ],
        "processes_alive": [
            "video_capture", "perception", "slam_vio_nav",
            "mission_planner", "comms", "payload_manager", "system_monitor"
        ]
    }
}
