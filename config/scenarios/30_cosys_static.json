{
    "_comment": "Scenario 30: Cosys-AirSim static proving ground — Tier 3 flight through populated Blocks env with stationary obstacles only (pillars, walls, chairs, couches, bushes, mannequins). Exercises depth → occupancy grid → D*Lite → potential-field avoider. Dynamic-obstacle counterpart is scenario 31.",
    "_epic": "#480 Phase A",
    "_issue": "#479",
    "scenario": {
        "name": "cosys_static",
        "description": "Flight through a populated Blocks environment with 9 static obstacles spawned via RPC. Validates every perception stage (radar, YOLO, depth) actually produces non-zero output, occupancy grid fills with known obstacles, and the avoider at least touches the plan.",
        "tier": 3,
        "timeout_s": 180,
        "requires_cosys_airsim": true,
        "scene": {
            "file": "config/scenes/cosys_static.json"
        },
        "backend_requirements": {
            "video_capture.mission_cam.backend": "cosys_airsim",
            "perception.detector.backend": "yolov8",
            "perception.depth_estimator.backend": "depth_anything_v2",
            "slam_vio_nav.imu_source.backend": "cosys_airsim",
            "slam_vio_nav.depth_source.backend": "cosys_airsim",
            "mission_planner.radar.backend": "cosys_airsim",
            "comms.mavlink.backend": "cosys_rpc"
        }
    },
    "config_overrides": {
        "video_capture": {
            "mission_cam": {
                "backend": "cosys_airsim",
                "endpoint": "127.0.0.1:41451",
                "camera_name": "mission_cam",
                "vehicle_name": "Drone0",
                "width": 1280,
                "height": 720,
                "fps": 30,
                "focal_length_mm": 25.0,
                "sensor_width_mm": 4.0
            },
            "stereo_cam": {
                "backend": "simulated",
                "width": 640,
                "height": 480,
                "fps": 20
            }
        },
        "perception": {
            "detector": {
                "backend": "yolov8",
                "model_path": "models/yolov8n.onnx",
                "confidence_threshold": 0.4,
                "iou_threshold": 0.45,
                "use_cuda": true
            },
            "depth_estimator": {
                "backend": "depth_anything_v2",
                "enabled": true,
                "model_path": "models/depth_anything_v2_vits.onnx",
                "use_cuda": true,
                "input_height": 384,
                "input_width": 384
            },
            "tracker": {
                "backend": "bytetrack",
                "max_age": 30,
                "min_hits": 3
            },
            "fusion": {
                "backend": "ukf",
                "process_noise_factor": 0.05,
                "measurement_noise_range": 0.1,
                "measurement_noise_bearing": 0.05
            }
        },
        "slam": {
            "vio": {
                "backend": "cosys_airsim"
            }
        },
        "slam_vio_nav": {
            "imu_source": {
                "backend": "cosys_airsim",
                "endpoint": "127.0.0.1:41451",
                "imu_name": "imu",
                "vehicle_name": "Drone0",
                "poll_interval_ms": 50
            },
            "depth_source": {
                "backend": "cosys_airsim",
                "endpoint": "127.0.0.1:41451",
                "camera_name": "DepthCam",
                "vehicle_name": "Drone0"
            }
        },
        "mission_planner": {
            "takeoff_altitude_m": 5.0,
            "acceptance_radius_m": 2.0,
            "overshoot_proximity_factor": 5.0,
            "cruise_speed_mps": 2.0,
            "survey_duration_s": 0,
            "path_planner": {
                "backend": "dstar_lite",
                "max_search_time_ms": 2000,
                "max_iterations": 250000,
                "z_band_cells": 0,
                "replan_interval_s": 0.5,
                "look_ahead_m": 0.0,
                "smoothing_alpha": 0.5,
                "yaw_towards_travel": true,
                "yaw_smoothing_rate": 0.3,
                "snap_approach_bias": 0.5
            },
            "obstacle_avoider": {
                "backend": "potential_field_3d"
            },
            "obstacle_avoidance": {
                "_comment": "WP3→WP4 gap: planner cruises at cruise_speed_mps=2.0, so a 2.0 clamp leaves no headroom for lateral repulsion to redirect the trajectory. Raised to 3.5 m/s (Issue #503). path_aware_bypass_hysteresis_m controls the re-enable distance once the drone clears the close regime (min_distance_m + hysteresis).",
                "min_distance_m": 2.5,
                "influence_radius_m": 10.0,
                "repulsive_gain": 3.0,
                "max_correction_mps": 3.5,
                "vertical_gain": 0.0,
                "path_aware": true,
                "path_aware_bypass_hysteresis_m": 0.5,
                "log_corrections": true
            },
            "occupancy_grid": {
                "resolution_m": 2.0,
                "inflation_radius_m": 2.5,
                "dynamic_obstacle_ttl_s": 2.0,
                "min_confidence": 0.5,
                "promotion_hits": 5,
                "max_static_cells": 1000
            },
            "static_obstacles": [],
            "_comment_static_obstacles": "No HD-map. Perception-driven avoidance via radar+camera+depth fusion — the RPC-spawned scene objects are the world.",
            "geofence": {
                "enabled": false
            },
            "waypoints": [
                {
                    "x": 0, "y": 0, "z": 5,
                    "yaw": 1.57, "speed": 2.0, "payload_trigger": false,
                    "_comment": "Start — takeoff point is the home spawn."
                },
                {
                    "x": 10, "y": 20, "z": 5,
                    "yaw": 1.57, "speed": 2.0, "payload_trigger": false,
                    "_comment": "Enter person cluster — person_01 and chair_01 are here."
                },
                {
                    "x": 25, "y": 12, "z": 5,
                    "yaw": -0.5, "speed": 2.0, "payload_trigger": false,
                    "_comment": "Fly between pillar_02 and wall_02 — forces tight avoidance."
                },
                {
                    "x": 10, "y": 2, "z": 5,
                    "yaw": -2.36, "speed": 2.0, "payload_trigger": false,
                    "_comment": "Approach bush_01 and person_02 — return-leg obstacles."
                },
                {
                    "x": 0, "y": 0, "z": 5,
                    "yaw": 0, "speed": 2.0, "payload_trigger": false,
                    "_comment": "Return home."
                }
            ],
            "_comment_waypoints": "5-waypoint mission routed through the 9 spawned static obstacles. acceptance_radius_m=2.0 to keep the drone close enough to obstacles to trigger avoidance."
        },
        "comms": {
            "mavlink": {
                "_comment": "Tier 3 uses SimpleFlight via AirSim RPC (see ADR-011 amendment for #490). Was PX4 before SimpleFlight decision.",
                "backend": "cosys_rpc",
                "heartbeat_rate_hz": 1,
                "timeout_ms": 8000
            }
        },
        "system_monitor": {
            "enable_thermal_monitoring": true,
            "enable_memory_monitoring": true,
            "watchdog_interval_ms": 500
        }
    },
    "validation": {
        "checks": [
            {
                "name": "Radar first scan",
                "path": "drone_logs/*.log",
                "pattern": "\\[CosysRadar\\] First scan: \\d+ detections",
                "min_matches": 1,
                "_comment": "CosysRadar backend successfully polled LiDAR data at least once."
            },
            {
                "name": "YOLO detections (non-zero)",
                "path": "drone_logs/*.log",
                "pattern": "\\[OpenCvYoloDetector\\].*detections=[1-9]",
                "min_matches": 10,
                "_comment": "YOLOv8 fired on the spawned objects — at least 10 non-empty detection frames."
            },
            {
                "name": "Depth Anything V2 running",
                "path": "drone_logs/*.log",
                "pattern": "\\[DepthAnythingV2\\]",
                "min_matches": 10,
                "_comment": "DA V2 pipeline actually running (enabled=true honoured)."
            },
            {
                "name": "Occupancy grid populated",
                "path": "drone_logs/*.log",
                "pattern": "\\[OccupancyGrid\\].*(promoted|occupied)=[1-9]",
                "min_matches": 1,
                "_comment": "At least one cell promoted from perception output."
            },
            {
                "name": "Avoider / D*Lite sees obstacles",
                "path": "drone_logs/*.log",
                "pattern": "(\\[D\\*Lite\\].*occupied=[1-9])|(\\[PotentialField.*corrected)",
                "min_matches": 1,
                "_comment": "D*Lite saw occupied cells or potential-field corrected the plan."
            },
            {
                "name": "VIO remained NOMINAL",
                "path": "drone_logs/*.log",
                "pattern": "health=DEGRADED",
                "min_matches": 0,
                "_comment": "Inverse check: zero DEGRADED events (Cosys ground-truth VIO should stay green)."
            },
            {
                "name": "Mission completed (LANDED)",
                "path": "drone_logs/*.log",
                "pattern": "\\[FSM\\].*LANDED",
                "min_matches": 1,
                "_comment": "FSM reached LANDED — drone navigated the full 5-waypoint loop."
            }
        ]
    }
}
