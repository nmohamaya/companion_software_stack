{
    "_comment": "Scenario 20: Radar degraded visibility — camera disabled, radar-only detection (Issue #231)",
    "scenario": {
        "name": "radar_degraded_visibility",
        "description": "Simulate degraded visibility (fog/darkness) where camera provides no detections. Radar-only tracks should be initiated and promoted after N consecutive frames. Validates radar_only_enabled and radar_orphan_promote_frames config.",
        "tier": 1,
        "timeout_s": 30,
        "requires_gazebo": false
    },
    "config_overrides": {
        "perception": {
            "detector": {
                "backend": "simulated",
                "sim": {
                    "min_detections": 0,
                    "max_detections": 0
                }
            },
            "tracker": {
                "backend": "bytetrack"
            },
            "fusion": {
                "backend": "ukf",
                "radar_only_enabled": true,
                "radar_orphan_promote_frames": 3,
                "radar": {
                    "enabled": true,
                    "range_std_m": 0.3,
                    "azimuth_std_rad": 0.026,
                    "elevation_std_rad": 0.026,
                    "velocity_std_mps": 0.1,
                    "gate_threshold": 9.21,
                    "ground_filter_enabled": true,
                    "min_object_altitude_m": 0.3,
                    "orphan_proximity_m": 3.0,
                    "default_radius_m": 1.5,
                    "max_orphan_range_m": 40.0,
                    "promotion_hits": 3
                }
            },
            "radar": {
                "backend": "simulated",
                "enabled": true
            }
        },
        "mission_planner": {
            "takeoff_altitude_m": 5.0,
            "acceptance_radius_m": 2.0,
            "cruise_speed_mps": 2.0,
            "path_planner": {
                "backend": "dstar_lite"
            },
            "obstacle_avoider": {
                "backend": "potential_field_3d"
            },
            "waypoints": [
                {"x": 10, "y": 0,  "z": 5, "yaw": 0,    "speed": 2.0, "payload_trigger": false},
                {"x": 10, "y": 10, "z": 5, "yaw": 1.57,  "speed": 2.0, "payload_trigger": false},
                {"x": 0,  "y": 0,  "z": 5, "yaw": -1.57, "speed": 2.0, "payload_trigger": false}
            ]
        }
    },
    "fault_sequence": {
        "steps": []
    },
    "pass_criteria": {
        "log_contains": [
            "TAKEOFF",
            "EXECUTING",
            "UKF.*radar_enabled=true"
        ],
        "log_must_not_contain": [
            "EMERGENCY_LAND"
        ],
        "processes_alive": [
            "video_capture", "perception", "slam_vio_nav",
            "mission_planner", "comms", "payload_manager"
        ]
    }
}
