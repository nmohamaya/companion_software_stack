{
    "_comment": "Default configuration for Drone Companion Stack",
    "log_level": "info",
    "ipc_backend": "zenoh",

    "zenoh": {
        "_comment": "Zenoh IPC settings",
        "shm_pool_size_mb": 32,
        "network": {
            "_comment": "Network transport: enables drone↔GCS communication over TCP/UDP",
            "enabled": false,
            "mode": "peer",
            "listen_port": 7447,
            "listen_address": "127.0.0.1",
            "protocol": "tcp",
            "connect_endpoints": [],
            "multicast_scouting": true,
            "gossip_scouting": true
        }
    },

    "video_capture": {
        "mission_cam": {
            "backend": "simulated",
            "width": 1920,
            "height": 1080,
            "fps": 30,
            "format": "RGB24"
        },
        "stereo_cam": {
            "backend": "simulated",
            "width": 640,
            "height": 480,
            "fps": 30,
            "format": "GRAY8"
        }
    },

    "perception": {
        "detector": {
            "backend": "simulated",
            "confidence_threshold": 0.5,
            "nms_threshold": 0.4,
            "max_detections": 64,
            "min_contour_area": 80,
            "subsample": 2,
            "max_fps": 0,
            "confidence_max": 0.95,
            "confidence_base": 0.5,
            "confidence_area_scale": 50.0,
            "sim": {
                "min_detections": 1,
                "max_detections": 5,
                "margin_px": 50.0,
                "size_min_px": 40.0,
                "size_max_px": 200.0,
                "confidence_min": 0.4,
                "confidence_max": 0.99,
                "num_classes": 5
            }
        },
        "tracker": {
            "backend": "bytetrack",
            "max_age": 10,
            "min_hits": 3,
            "max_association_cost": 100.0,
            "high_conf_threshold": 0.5,
            "low_conf_threshold": 0.1,
            "max_iou_cost": 0.7
        },
        "radar": {
            "backend": "simulated",
            "enabled": false,
            "_comment_update_rate": "update_rate_hz reserved for GazeboRadar plugin (#212)",
            "update_rate_hz": 20,
            "max_range_m": 100.0,
            "fov_azimuth_rad": 1.047,
            "fov_elevation_rad": 0.698,
            "ground_filter_alt_m": 2.0,
            "noise": {
                "range_std_m": 0.3,
                "azimuth_std_rad": 0.026,
                "elevation_std_rad": 0.026,
                "velocity_std_mps": 0.1
            },
            "false_alarm_rate": 0.02,
            "num_targets": 3
        },
        "fusion": {
            "rate_hz": 30,
            "camera_weight": 1.0,
            "camera_height_m": 1.5,
            "depth": {
                "covariance_init": 5.0,
                "bbox_h_threshold": 10.0,
                "depth_min_m": 1.0,
                "depth_max_m": 40.0,
                "ray_down_threshold": 0.01,
                "fallback_depth_m": 8.0
            },
            "radar": {
                "enabled": false,
                "range_std_m": 0.3,
                "azimuth_std_rad": 0.026,
                "elevation_std_rad": 0.026,
                "velocity_std_mps": 0.1,
                "gate_threshold": 9.21,
                "ground_filter_enabled": true,
                "min_object_altitude_m": 1.5,
                "altitude_gate_m": 2.0,
                "orphan_proximity_m": 5.0,
                "max_orphan_range_m": 25.0,
                "promotion_hits": 6
            }
        }
    },

    "slam": {
        "vio_rate_hz": 100,
        "visual_frontend_rate_hz": 30,
        "imu_rate_hz": 400,
        "vio": {
            "backend": "simulated",
            "gz_topic": "/model/x500_companion_0/odometry",
            "quality": {
                "good_trace_max": 0.1,
                "degraded_trace_max": 1.0
            }
        },
        "imu": {
            "backend": "simulated"
        },
        "keyframe": {
            "min_parallax_px": 15.0,
            "min_tracked_ratio": 0.6,
            "max_time_sec": 0.5
        }
    },

    "mission_planner": {
        "update_rate_hz": 10,
        "takeoff_altitude_m": 5.0,
        "acceptance_radius_m": 1.0,
        "cruise_speed_mps": 2.0,
        "rtl_acceptance_radius_m": 1.5,
        "landed_altitude_m": 0.5,
        "rtl_min_dwell_seconds": 5,
        "path_planner": {
            "backend": "dstar_lite",
            "ramp_dist_m": 3.0,
            "min_speed_mps": 1.0,
            "snap_search_radius": 8,
            "yaw_towards_travel": true,
            "yaw_smoothing_rate": 0.3,
            "snap_approach_bias": 0.5
        },
        "occupancy_grid": {
            "resolution_m": 0.5,
            "inflation_radius_m": 1.5,
            "dynamic_obstacle_ttl_s": 3.0,
            "min_confidence": 0.3,
            "min_promotion_depth_confidence": 0.8,
            "max_static_cells": 0,
            "prediction_enabled": true,
            "prediction_dt_s": 2.0
        },
        "obstacle_avoider": {
            "backend": "potential_field_3d"
        },
        "obstacle_avoidance": {
            "min_distance_m": 2.0,
            "influence_radius_m": 5.0,
            "repulsive_gain": 2.0,
            "max_correction_mps": 3.0,
            "min_confidence": 0.3,
            "prediction_dt_s": 0.5,
            "max_age_ms": 500
        },
        "geofence": {
            "polygon": [
                {"x": -50, "y": -50},
                {"x":  50, "y": -50},
                {"x":  50, "y":  50},
                {"x": -50, "y":  50}
            ],
            "altitude_floor_m": 0.0,
            "altitude_ceiling_m": 120.0,
            "warning_margin_m": 5.0,
            "altitude_tolerance_m": 0.5
        },
        "collision_recovery": {
            "enabled": true,
            "climb_delta_m": 3.0,
            "hover_duration_s": 2.0
        },
        "waypoints": [
            {"x": 10, "y": 0,  "z": 5, "yaw": 0,    "speed": 2.0, "payload_trigger": false},
            {"x": 10, "y": 10, "z": 5, "yaw": 1.57,  "speed": 2.0, "payload_trigger": true},
            {"x": 0,  "y": 10, "z": 5, "yaw": 3.14,  "speed": 2.0, "payload_trigger": false},
            {"x": 0,  "y": 0,  "z": 5, "yaw": -1.57, "speed": 2.0, "payload_trigger": true}
        ]
    },

    "comms": {
        "mavlink": {
            "backend": "simulated",
            "serial_port": "/dev/ttyTHS1",
            "baud_rate": 921600,
            "heartbeat_rate_hz": 1,
            "tx_rate_hz": 20,
            "rx_rate_hz": 10
        },
        "gcs": {
            "backend": "simulated",
            "udp_port": 14550,
            "telemetry_rate_hz": 2
        }
    },

    "payload_manager": {
        "update_rate_hz": 50,
        "gimbal": {
            "backend": "simulated",
            "max_slew_rate_dps": 60.0,
            "pitch_min_deg": -90.0,
            "pitch_max_deg": 30.0,
            "yaw_min_deg": -180.0,
            "yaw_max_deg": 180.0,
            "auto_track": {
                "enabled": false,
                "min_confidence": 0.5
            }
        }
    },

    "fault_manager": {
        "pose_stale_timeout_ms": 500,
        "battery_warn_percent": 30.0,
        "battery_rtl_percent": 20.0,
        "battery_crit_percent": 10.0,
        "fc_link_lost_timeout_ms": 3000,
        "fc_link_rtl_timeout_ms": 15000,
        "loiter_escalation_timeout_s": 30
    },

    "system_monitor": {
        "update_rate_hz": 1,
        "disk_check_interval_s": 10,
        "thresholds": {
            "cpu_warn_percent": 90.0,
            "mem_warn_percent": 90.0,
            "temp_warn_c": 105.0,
            "temp_crit_c": 120.0,
            "_comment_thermal": "Dev-safe thresholds (raised from 80/95 to avoid false FAULT_THERMAL_CRITICAL on hot dev machines). For real hardware, use config/hardware.json with thresholds calibrated to the host SBC's thermal runaway characteristics.",
            "battery_warn_percent": 20.0,
            "battery_crit_percent": 10.0,
            "disk_crit_percent": 98.0
        }
    },

    "watchdog": {
        "_comment": "Process watchdog configuration (Phase 4)",
        "thread_stuck_threshold_ms": 5000,
        "thread_scan_interval_ms": 1000,
        "processes": {
            "video_capture": {
                "critical": false,
                "max_restarts": 3,
                "cooldown_s": 60,
                "backoff_ms": 500,
                "max_backoff_ms": 30000,
                "thermal_gate": 3,
                "launch_after": [],
                "restart_cascade": []
            },
            "perception": {
                "critical": false,
                "max_restarts": 5,
                "cooldown_s": 60,
                "backoff_ms": 500,
                "max_backoff_ms": 30000,
                "thermal_gate": 3,
                "launch_after": ["video_capture"],
                "restart_cascade": []
            },
            "slam_vio_nav": {
                "critical": true,
                "max_restarts": 5,
                "cooldown_s": 60,
                "backoff_ms": 500,
                "max_backoff_ms": 30000,
                "thermal_gate": 3,
                "launch_after": ["perception"],
                "restart_cascade": ["perception"]
            },
            "comms": {
                "critical": true,
                "max_restarts": 5,
                "cooldown_s": 60,
                "backoff_ms": 500,
                "max_backoff_ms": 30000,
                "thermal_gate": 3,
                "launch_after": [],
                "restart_cascade": ["mission_planner", "payload_manager"]
            },
            "mission_planner": {
                "critical": false,
                "max_restarts": 5,
                "cooldown_s": 60,
                "backoff_ms": 500,
                "max_backoff_ms": 30000,
                "thermal_gate": 3,
                "launch_after": ["comms", "slam_vio_nav"],
                "restart_cascade": []
            },
            "payload_manager": {
                "critical": false,
                "max_restarts": 3,
                "cooldown_s": 60,
                "backoff_ms": 500,
                "max_backoff_ms": 30000,
                "thermal_gate": 3,
                "launch_after": ["comms"],
                "restart_cascade": []
            }
        }
    }
}
