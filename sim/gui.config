<?xml version="1.0" ?>
<!-- sim/gui.config
     Gazebo GUI client configuration for companion-stack SITL.
     Used with: gz sim -g --gui-config sim/gui.config
     Camera starts behind the drone at origin with CameraTracking enabled
     so the view can follow the drone during flight.
-->
<window>
  <width>1280</width>
  <height>720</height>

  <plugin filename="MinimalScene" name="3D View">
    <gz-gui>
      <title>3D View</title>
      <property type="bool" key="showTitleBar">false</property>
      <property type="string" key="state">docked</property>
    </gz-gui>
    <engine>ogre2</engine>
    <scene>scene</scene>
    <ambient_light>0.4 0.4 0.4</ambient_light>
    <background_color>0.7 0.8 0.9</background_color>
    <!-- Chase-cam: slightly behind and above the drone at origin -->
    <camera_pose>-4 0 2 0 0.25 0</camera_pose>
    <camera_clip>
      <near>0.25</near>
      <far>25000</far>
    </camera_clip>
  </plugin>

  <plugin filename="GzSceneManager" name="Scene Manager">
    <gz-gui>
      <property type="bool" key="showTitleBar">false</property>
      <property type="string" key="state">docked</property>
    </gz-gui>
  </plugin>

  <plugin filename="InteractiveViewControl" name="Interactive view control">
    <gz-gui>
      <property type="bool" key="showTitleBar">false</property>
      <property type="string" key="state">docked</property>
    </gz-gui>
  </plugin>

  <plugin filename="CameraTracking" name="Camera tracking">
    <gz-gui>
      <property type="bool" key="showTitleBar">false</property>
      <property type="string" key="state">docked</property>
    </gz-gui>
  </plugin>

  <plugin filename="EntityTree" name="Entity tree">
    <gz-gui>
      <property type="string" key="state">docked</property>
    </gz-gui>
  </plugin>
</window>
