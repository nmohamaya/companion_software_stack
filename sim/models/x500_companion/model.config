<?xml version="1.0" encoding="UTF-8"?>
<model>
  <name>x500_companion</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Companion Stack</name>
  </author>
  <description>
    PX4 x500 quadrotor with companion-computer sensors:
    mission camera (640×480 RGB, 30 Hz),
    stereo left camera (640×480 L8, 30 Hz),
    and IMU (200 Hz with Gaussian noise).
    Sensors are attached to base_link via fixed joints.
  </description>
</model>
