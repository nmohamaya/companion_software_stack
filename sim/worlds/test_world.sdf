<?xml version="1.0" encoding="UTF-8"?>
<!-- sim/worlds/test_world.sdf
     Gazebo Harmonic world for companion-stack integration testing.
     - Flat ground plane with obstacle boxes/cylinders
     - PX4 x500 quadrotor with mission camera, stereo camera, and IMU
     - Landing pad at origin

     Usage:
       PX4_GZ_WORLD=$PWD/sim/worlds/test_world.sdf \
       PX4_SIM_MODEL=x500 make px4_sitl gz_x500
-->
<sdf version="1.9">
  <world name="test_world">

    <!-- ═══ Physics ════════════════════════════════════════════ -->
    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>

    <!-- ═══ Scene ═════════════════════════════════════════════ -->
    <scene>
      <grid>false</grid>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.8 0.9 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- ═══ Ground Plane ══════════════════════════════════════ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>1 1</size>
            </plane>
          </geometry>
          <surface>
            <friction><ode/></friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.5 0.6 0.5 1</ambient>
            <diffuse>0.5 0.6 0.5 1</diffuse>
            <specular>0.3 0.3 0.3 1</specular>
          </material>
        </visual>
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <mass>1</mass>
          <inertia>
            <ixx>1</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>1</iyy><iyz>0</iyz><izz>1</izz>
          </inertia>
        </inertial>
      </link>
      <pose>0 0 0 0 0 0</pose>
    </model>

    <!-- ═══ Landing Pad at Origin ═════════════════════════════ -->
    <model name="landing_pad">
      <static>true</static>
      <pose>0 0 0.01 0 0 0</pose>
      <link name="pad_link">
        <visual name="pad_visual">
          <geometry>
            <cylinder>
              <radius>1.5</radius>
              <length>0.02</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.8 0.2 0.2 1</ambient>
            <diffuse>0.8 0.2 0.2 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══ Obstacle 1: Box at (8, 3) ════════════════════════ -->
    <model name="obstacle_box_1">
      <static>true</static>
      <pose>8 3 1 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1 1 2</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1 1 2</size></box></geometry>
          <material>
            <ambient>0.7 0.4 0.2 1</ambient>
            <diffuse>0.7 0.4 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══ Obstacle 2: Cylinder at (10, 5) ══════════════════ -->
    <model name="obstacle_cylinder_1">
      <static>true</static>
      <pose>10 5 1.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.5</radius><length>3</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.5</radius><length>3</length></cylinder></geometry>
          <material>
            <ambient>0.3 0.3 0.7 1</ambient>
            <diffuse>0.3 0.3 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══ Obstacle 3: Box at (5, 8) ════════════════════════ -->
    <model name="obstacle_box_2">
      <static>true</static>
      <pose>5 8 0.75 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>2 0.5 1.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>2 0.5 1.5</size></box></geometry>
          <material>
            <ambient>0.6 0.6 0.2 1</ambient>
            <diffuse>0.6 0.6 0.2 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══ Sun ═══════════════════════════════════════════════ -->
    <light name="sun" type="directional">
      <pose>0 0 500 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1</intensity>
      <direction>0.001 0.625 -0.78</direction>
      <diffuse>0.904 0.904 0.904 1</diffuse>
      <specular>0.271 0.271 0.271 1</specular>
      <attenuation>
        <range>2000</range>
        <linear>0</linear>
        <constant>1</constant>
        <quadratic>0</quadratic>
      </attenuation>
      <spot>
        <inner_angle>0</inner_angle>
        <outer_angle>0</outer_angle>
        <falloff>0</falloff>
      </spot>
    </light>

    <!-- ═══ Geo-Reference (Zurich, same as PX4 default) ══════ -->
    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>47.397971057728974</latitude_deg>
      <longitude_deg>8.546163739800146</longitude_deg>
      <elevation>0</elevation>
    </spherical_coordinates>

    <!-- ═══ Quadrotor: PX4 x500 with sensors ═════════════════ -->
    <!-- The actual x500 model is spawned by PX4 SITL via
         PX4_GZ_MODEL_NAME. We define companion sensors here
         that attach to the drone's base_link via fixed joints.
         NOTE: When using PX4's built-in model spawning, the
         sensors below are included via a custom model overlay.
         For standalone testing, include the x500 model directly. -->

    <!-- Mission Camera (forward-facing, 640x480 RGB, 30 Hz) -->
    <model name="mission_camera_model">
      <static>false</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="mission_camera_link">
        <inertial>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.00004</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.00004</iyy><iyz>0</iyz><izz>0.00004</izz>
          </inertia>
        </inertial>
        <visual name="cam_housing">
          <geometry><box><size>0.02 0.04 0.04</size></box></geometry>
        </visual>
        <sensor name="mission_camera" type="camera">
          <gz_frame_id>mission_camera_link</gz_frame_id>
          <pose>0 0 0 0 0 0</pose>
          <camera>
            <horizontal_fov>1.39</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>500</far>
            </clip>
          </camera>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <visualize>true</visualize>
          <topic>/camera</topic>
        </sensor>
      </link>
    </model>

    <!-- Stereo Left Camera (forward-facing, 640x480 GRAY, 30 Hz) -->
    <model name="stereo_left_model">
      <static>false</static>
      <pose>0 0.06 0 0 0 0</pose>
      <link name="stereo_left_link">
        <inertial>
          <mass>0.05</mass>
          <inertia>
            <ixx>0.00004</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.00004</iyy><iyz>0</iyz><izz>0.00004</izz>
          </inertia>
        </inertial>
        <visual name="stereo_housing">
          <geometry><box><size>0.02 0.04 0.04</size></box></geometry>
        </visual>
        <sensor name="stereo_left" type="camera">
          <gz_frame_id>stereo_left_link</gz_frame_id>
          <pose>0 0 0 0 0 0</pose>
          <camera>
            <horizontal_fov>1.39</horizontal_fov>
            <image>
              <width>640</width>
              <height>480</height>
              <format>L8</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>500</far>
            </clip>
          </camera>
          <always_on>1</always_on>
          <update_rate>30</update_rate>
          <visualize>false</visualize>
          <topic>/stereo_left</topic>
        </sensor>
      </link>
    </model>

    <!-- IMU Sensor (200 Hz) -->
    <model name="companion_imu_model">
      <static>false</static>
      <pose>0 0 0.05 0 0 0</pose>
      <link name="companion_imu_link">
        <inertial>
          <mass>0.01</mass>
          <inertia>
            <ixx>0.00001</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>0.00001</iyy><iyz>0</iyz><izz>0.00001</izz>
          </inertia>
        </inertial>
        <sensor name="companion_imu" type="imu">
          <gz_frame_id>companion_imu_link</gz_frame_id>
          <imu>
            <angular_velocity>
              <x><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></x>
              <y><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></y>
              <z><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></z>
            </angular_velocity>
            <linear_acceleration>
              <x><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></x>
              <y><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></y>
              <z><noise type="gaussian"><mean>0</mean><stddev>0.05</stddev></noise></z>
            </linear_acceleration>
          </imu>
          <always_on>1</always_on>
          <update_rate>200</update_rate>
          <visualize>false</visualize>
          <topic>/imu</topic>
        </sensor>
      </link>
    </model>

  </world>
</sdf>
