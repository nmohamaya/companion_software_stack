<?xml version="1.0" encoding="UTF-8"?>
<!-- sim/worlds/test_world.sdf
     Gazebo Harmonic world for companion-stack integration testing.
     - Flat ground plane with obstacle boxes/cylinders
     - Landing pad at origin

     The x500_companion model (with mission camera, stereo camera,
     and IMU attached via fixed joints) is spawned by PX4 SITL.
     See sim/models/x500_companion/model.sdf.

     Usage:
       GZ_SIM_RESOURCE_PATH=$PWD/sim/models:$PX4_DIR/Tools/simulation/gz/models \
       PX4_GZ_WORLD_FILE=$PWD/sim/worlds/test_world.sdf \
       PX4_GZ_MODEL=x500_companion make px4_sitl gz_x500
-->
<sdf version="1.9">
  <world name="test_world">

    <!-- ═══ Physics ════════════════════════════════════════════ -->
    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>

    <!-- ═══ Scene ═════════════════════════════════════════════ -->
    <scene>
      <grid>false</grid>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.8 0.9 1</background>
      <shadows>true</shadows>
    </scene>

    <!-- ═══ GUI — chase-cam behind drone at spawn ═════════════ -->
    <gui fullscreen="0">
      <plugin filename="MinimalScene" name="3D View">
        <gz-gui>
          <title>3D View</title>
          <property type="bool" key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.4 0.4 0.4</ambient_light>
        <background_color>0.7 0.8 0.9</background_color>
        <!-- Behind and slightly above the drone at origin -->
        <camera_pose>-4 0 2 0 0.25 0</camera_pose>
        <camera_clip>
          <near>0.25</near>
          <far>25000</far>
        </camera_clip>
      </plugin>
      <plugin filename="GzSceneManager" name="Scene Manager">
        <gz-gui>
          <property type="bool" key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
      </plugin>
      <plugin filename="InteractiveViewControl" name="Interactive view control">
        <gz-gui>
          <property type="bool" key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
      </plugin>
      <plugin filename="CameraTracking" name="Camera tracking">
        <gz-gui>
          <property type="bool" key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </gz-gui>
      </plugin>
      <plugin filename="EntityTree" name="Entity tree">
        <gz-gui>
          <property type="string" key="state">docked</property>
        </gz-gui>
      </plugin>
    </gui>

    <!-- ═══ Ground Plane ══════════════════════════════════════ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <surface>
            <friction><ode/></friction>
            <bounce/>
            <contact/>
          </surface>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.5 0.6 0.5 1</ambient>
            <diffuse>0.5 0.6 0.5 1</diffuse>
            <specular>0.3 0.3 0.3 1</specular>
          </material>
        </visual>
        <pose>0 0 0 0 0 0</pose>
        <inertial>
          <mass>1</mass>
          <inertia>
            <ixx>1</ixx><ixy>0</ixy><ixz>0</ixz>
            <iyy>1</iyy><iyz>0</iyz><izz>1</izz>
          </inertia>
        </inertial>
      </link>
      <pose>0 0 0 0 0 0</pose>
    </model>

    <!-- ═══ Landing Pad at Origin ═════════════════════════════ -->
    <model name="landing_pad">
      <static>true</static>
      <pose>0 0 0.01 0 0 0</pose>
      <link name="pad_link">
        <visual name="pad_visual">
          <geometry>
            <cylinder>
              <radius>1.5</radius>
              <length>0.02</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.8 0.2 0.2 1</ambient>
            <diffuse>0.8 0.2 0.2 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══ Obstacles — 4 well-spaced (≥10m apart) for Scenario 18 ═══ -->
    <!-- Layout: rectangular field with clear 5m+ corridors between obstacles.
         Drone routes through the field using D* Lite + camera perception.
         All obstacles reach flight altitude (4–5m) to force lateral avoidance. -->

    <!-- Obstacle 1: RED cylinder — near origin→WP1 leg -->
    <model name="obstacle_red_cylinder">
      <static>true</static>
      <pose>3 15 2.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>1.0</radius><length>5</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>1.0</radius><length>5</length></cylinder></geometry>
          <material>
            <ambient>0.9 0.1 0.1 1</ambient>
            <diffuse>0.9 0.1 0.1 1</diffuse>
            <specular>0.4 0.1 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle 2: GREEN cylinder — center of field, near WP2→WP3 leg -->
    <model name="obstacle_green_cylinder">
      <static>true</static>
      <pose>10 10 2.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>1.0</radius><length>5</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>1.0</radius><length>5</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.85 0.1 1</ambient>
            <diffuse>0.1 0.85 0.1 1</diffuse>
            <specular>0.1 0.4 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle 3: BLUE cylinder — east side, near WP3→WP4 leg -->
    <model name="obstacle_blue_cylinder">
      <static>true</static>
      <pose>18 5 2.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.8</radius><length>5</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.8</radius><length>5</length></cylinder></geometry>
          <material>
            <ambient>0.1 0.1 0.9 1</ambient>
            <diffuse>0.1 0.1 0.9 1</diffuse>
            <specular>0.1 0.1 0.4 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Obstacle 4: ORANGE box — on return leg toward home -->
    <model name="obstacle_orange_box">
      <static>true</static>
      <pose>5 3 2.0 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.5 1.5 4</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.5 1.5 4</size></box></geometry>
          <material>
            <ambient>0.95 0.5 0.05 1</ambient>
            <diffuse>0.95 0.5 0.05 1</diffuse>
            <specular>0.4 0.2 0.05 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══ Sun ═══════════════════════════════════════════════ -->
    <light name="sun" type="directional">
      <pose>0 0 500 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1</intensity>
      <direction>0.001 0.625 -0.78</direction>
      <diffuse>0.904 0.904 0.904 1</diffuse>
      <specular>0.271 0.271 0.271 1</specular>
      <attenuation>
        <range>2000</range>
        <linear>0</linear>
        <constant>1</constant>
        <quadratic>0</quadratic>
      </attenuation>
    </light>

    <!-- ═══ Geo-Reference (Zurich, same as PX4 default) ══════ -->
    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>47.397971057728974</latitude_deg>
      <longitude_deg>8.546163739800146</longitude_deg>
      <elevation>0</elevation>
    </spherical_coordinates>

  </world>
</sdf>
