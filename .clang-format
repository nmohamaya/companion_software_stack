# Clang-Format configuration for Drone Companion Software Stack
# Style: project-specific, based on existing codebase conventions
# Version: clang-format 18 (Ubuntu 24.04)

Language: Cpp
Standard: c++17

# ── Indentation ──────────────────────────────────────────────────
IndentWidth: 4
TabWidth: 4
UseTab: Never
IndentCaseLabels: true
NamespaceIndentation: None
IndentPPDirectives: None
IndentWrappedFunctionNames: false
ContinuationIndentWidth: 4

# ── Braces ───────────────────────────────────────────────────────
BreakBeforeBraces: Attach
# Allman-style lambda braces are handled by Attach (brace on same line)

# ── Line width ───────────────────────────────────────────────────
ColumnLimit: 100

# ── Alignment ────────────────────────────────────────────────────
PointerAlignment: Left
ReferenceAlignment: Left
AlignAfterOpenBracket: Align
AlignConsecutiveAssignments: Consecutive
AlignConsecutiveDeclarations: Consecutive
AlignConsecutiveMacros: None
AlignEscapedNewlines: Left
AlignOperands: Align
AlignTrailingComments: true

# ── Access modifiers ────────────────────────────────────────────
AccessModifierOffset: -4

# ── Includes ─────────────────────────────────────────────────────
IncludeBlocks: Regroup
IncludeCategories:
  # 1. Main header (auto-detected by clang-format)
  - Regex:    '".*"'
    Priority: 1
  # 2. Standard library
  - Regex:    '<[a-z_]+>'
    Priority: 2
  # 3. Third-party (Eigen, spdlog, gtest, nlohmann, etc.)
  - Regex:    '<.*>'
    Priority: 3
SortIncludes: CaseSensitive

# ── Spaces ───────────────────────────────────────────────────────
SpaceAfterCStyleCast: false
SpaceAfterLogicalNot: false
SpaceAfterTemplateKeyword: false
SpaceBeforeAssignmentOperators: true
SpaceBeforeCaseColon: false
SpaceBeforeParens: ControlStatements
SpaceBeforeRangeBasedForLoopColon: true
SpaceInEmptyBlock: false
SpaceInEmptyParentheses: false
SpacesBeforeTrailingComments: 2
SpacesInAngles: Never
SpacesInCStyleCastParentheses: false
SpacesInContainerLiterals: true
SpacesInParentheses: false
SpacesInSquareBrackets: false

# ── Breaks & wrapping ───────────────────────────────────────────
AllowAllArgumentsOnNextLine: true
AllowAllParametersOfDeclarationOnNextLine: true
AllowShortBlocksOnASingleLine: Empty
AllowShortCaseLabelsOnASingleLine: true
AllowShortFunctionsOnASingleLine: Inline
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortLambdasOnASingleLine: Inline
AllowShortLoopsOnASingleLine: true
AlwaysBreakAfterReturnType: None
AlwaysBreakBeforeMultilineStrings: false
AlwaysBreakTemplateDeclarations: Yes
BinPackArguments: true
BinPackParameters: true
BreakBeforeBinaryOperators: None
BreakBeforeTernaryOperators: true
BreakConstructorInitializers: BeforeComma
BreakInheritanceList: BeforeComma
PackConstructorInitializers: NextLine

# ── Penalties ────────────────────────────────────────────────────
PenaltyBreakAssignment: 25
PenaltyBreakBeforeFirstCallParameter: 19
PenaltyBreakComment: 300
PenaltyBreakFirstLessLess: 120
PenaltyBreakString: 1000
PenaltyExcessCharacter: 100
PenaltyReturnTypeOnItsOwnLine: 200

# ── Other ────────────────────────────────────────────────────────
FixNamespaceComments: true
MaxEmptyLinesToKeep: 2
ReflowComments: false
SortUsingDeclarations: false
Cpp11BracedListStyle: true
DerivePointerAlignment: false
InsertBraces: false
InsertNewlineAtEOF: true
RemoveSemicolon: false
